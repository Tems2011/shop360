class CustomerProfile {

    // DISPLAY PROFILE FORM
    function displayProfileForm(){

        echo "

        <!DOCTYPE html>

        <html>

        <head>

            <title>Customer Profile</title>

            <link
            href='
https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css'
            rel='stylesheet'
            >

            <style>

                body{

                    background:#111;
                    color:white;

                }

                .profile-box{

                    background:#1c1c1c;
                    border:2px solid gold;
                    border-radius:15px;
                    padding:30px;
                    margin-top:50px;
                    box-shadow:0px 0px 15px rgba(255,215,0,0.3);

                }

                .title{

                    color:gold;
                    font-weight:bold;

                }

                .btn-save{

                    background:gold;
                    color:black;
                    font-weight:bold;

                }

                .btn-save:hover{

                    background:darkgoldenrod;
                    color:white;

                }

            </style>

        </head>

        <body>

        <div class='container'>

            <div class='row justify-content-center'>

                <div class='col-md-7'>

                    <div class='profile-box'>

                        <h2 class='title text-center mb-4'>

                            Customer Profile

                        </h2>

                        <form
                            action='processes/profileprocess.php'
                            method='POST'
                        >

                            <div class='mb-3'>

                                <label>
                                    Full Name
                                </label>

                                <input
                                    type='text'
                                    name='fullname'
                                    class='form-control'
                                    placeholder='Enter Full Name'
                                >

                            </div>

                            <div class='mb-3'>

                                <label>
                                    Phone Number
                                </label>

                                <input
                                    type='text'
                                    name='phone'
                                    class='form-control'
                                    placeholder='Enter Phone Number'
                                >

                            </div>

                            <div class='mb-3'>

                                <label>
                                    Gender
                                </label>

                                <select
                                    name='gender'
                                    class='form-control'
                                >

                                    <option value=''>
                                        Select Gender
                                    </option>

                                    <option>
                                        Male
                                    </option>

                                    <option>
                                        Female
                                    </option>

                                </select>

                            </div>

                            <div class='mb-3'>

                                <label>
                                    Address
                                </label>

                                <textarea
                                    name='address'
                                    class='form-control'
                                    placeholder='Enter Address'
                                ></textarea>

                            </div>

                            <div class='mb-3'>

                                <label>
                                    Country
                                </label>

                                <input
                                    type='text'
                                    name='country'
                                    class='form-control'
                                    placeholder='Enter Country'
                                >

                            </div>

                            <button
                                type='submit'
                                class='btn btn-save w-100'
                            >

                                Save Profile

                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

        </body>

        </html>

        ";

    }

}

$profile = new CustomerProfile();

$profile->displayProfileForm();

